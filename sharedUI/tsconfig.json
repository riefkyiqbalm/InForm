{
 "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "types" : ["chrome","node"],
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": false,
    "noEmit": false,
    "paths": {
        "@sharedUI/*": ["./src/*"],
        "@sharedUI/types/*": ["./src/types/index.ts"]
    }
  },
  "include": ["src/**/*", "src/context/ToastContext.tsx", "src/components/SettingsModal.tsx", "src/components/buttons/AttachButton.tsx", "src/components/buttons/LogOutButton.tsx", "src/context/AuthContext.tsx", "src/components/buttons/NavigationButton.tsx", "src/components/buttons/NewButton.tsx", "src/lib/constants/suggestions.ts", "src/components/chats/DefaultPrompt.tsx", "../browser-extension/hooks", "../browser-extension/emails",],
  "exclude": ["node_modules", "dist"]
}