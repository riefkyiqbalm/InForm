{
  "compilerOptions": {
    /* Basic Options */
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "incremental": true,

    /* Module Resolution */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    /* Strict Checks */
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    /* Build Options */
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src", 

    /* Paths Aliases */
    "paths": {
      "@sharedUI/*": ["./src/*"]
    },

    /* Types */
    "types": ["chrome", "node"]
  },
  "include": [
    "src/**/*",         // Semua file di bawah folder src
    "next-env.d.ts"     // File env Next.js jika diperlukan
, "src/context/AuthContext.tsx"  ],
  "exclude": [
    "node_modules", 
    "dist",
    "**/*.test.ts",
    "**/*.spec.ts"
  ]
}