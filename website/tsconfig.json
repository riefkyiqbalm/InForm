{
  "compilerOptions": {
    // "ignoreDeprecations": "6.0",
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ESNext"
    ],
    "module": "ESNext",
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "incremental": true,
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["chrome", "node"],
    "paths": {
      "@/*": [
        "./src/*"
      ],
     "@sharedUI/*": ["../sharedUI/src/*"],
     "@sharedUI/types/": ["../sharedUI/src/types/index.ts"]
    },
    "allowJs": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-auth.d.ts",
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
, "src/app/api/chat/sessions/[id]/[sessionsId]/route.DELETEts", "src/lib/api.ts", "src/lib/auth.ts", "src/lib/db.ts", "src/lib/email.ts", "src/lib/errors.ts", "src/lib/index.ts", "src/lib/prisma.ts", "src/lib/validators.ts", "src/app/providers.tsx", "src/app/api/auth/[...nextauth]/route.ts", "../sharedUI/src/components/buttons/ForgotPassword.tsx"  ],
  "exclude": [
    "node_modules"
  ]
}
