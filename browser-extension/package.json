{
  "name": "inform",
  "displayName": "",
  "version": "0.0.1",
  "description": "An AI-chatbot extension for browser",
  "author": "PT Japa Teknika Indonesia <inti@japatek.id>",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package",
    "gen:icons": "node genIcon.js"
  },
  "dependencies": {
    "@plasmohq/storage": "^1.13.0",
    "@react-email/components": "1.0.12",
    "js-cookie": "^3.0.5",
    "jsonwebtoken": "^9.0.3",
    "plasmo": "^0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "resend": "6.12.0"
  },
  "manifest": {
    "externally_connectable": {
      "matches": [
        "http://localhost:3000/*"
      ]
    },
    "permissions": [
      "storage",
      "sidePanel",
      "tabs",
      "cookies"
    ],
    "icons": {
      "16": "../assets/icon.png",
      "48": "../assets/icon.png",
      "128": "../assets/icon.png"
    },
    "action": {
      "default_icon": "../assets/icon.png"
    },
    "host_permissions": [
      "https://*/*",
      "http://localhost:3000/*"
    ],
    "side_panel": {
      "default_path": "sidepanel.html"
    }
  },
  "devDependencies": {
    "@types/chrome": "^0.1.40",
    "@types/node": "^25.6.0"
  }
}
